# --- App ---
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
APP_SECRET_KEY=change-me-to-a-long-random-string
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=change-me-to-a-fernet-key

# --- Docker host ports ---
# Override these if you already have containers using the default ports.
# The in-container ports are fixed; only the host-side mapping changes.
APP_HOST_PORT=8080
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
MLFLOW_HOST_PORT=5000

# --- Database (Postgres + TimescaleDB) ---
POSTGRES_USER=daytrader
POSTGRES_PASSWORD=daytrader
POSTGRES_DB=daytrader
DATABASE_URL=postgresql+asyncpg://daytrader:daytrader@postgres:5432/daytrader

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- mlflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Phase 0 auth stub: default tenant + user ---
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_NAME=default
DEFAULT_USER_EMAIL=operator@local

# --- AG Grid / AG Charts Enterprise license ---
AG_GRID_LICENSE_KEY=

# --- Data providers ---
# Crypto (Binance testnet for Phase 0)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true

# Equities (Phase 2)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# Macro
FRED_API_KEY=

# News / sentiment
NEWSAPI_KEY=
