# Production .env for the Linux deploy host (~/daytrader/.env).
#
# This is the env-file mounted into the app + db containers by
# docker-compose.yml. The dev `.env.example` covers a different (richer)
# set of vars suited to a local `docker compose -f docker-compose.dev.yml`
# stack — don't confuse the two.
#
# Generate / fill values, then `chmod 600 ~/daytrader/.env`.

# --- Postgres -----------------------------------------------------------------
# Used by the db service AND interpolated into DATABASE_URL inside compose.
# Pick a reasonable random string; ~16 chars is plenty.
POSTGRES_PASSWORD=

# --- App secrets --------------------------------------------------------------
# 32+ char random for NiceGUI session-cookie signing. Rotating logs all
# users out — fine.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
APP_SECRET_KEY=

# Fernet key for encrypting broker credentials in the DB. Once set,
# DON'T change without re-encrypting first (admin/rotate_encryption_key.py).
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# --- Bootstrap super admin (used once at first start) -------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@daytrader.local
BOOTSTRAP_ADMIN_PASSWORD=

# --- App env tag --------------------------------------------------------------
APP_ENV=production

# --- Optional integrations (per-tenant broker creds via UI override these) ---
AG_GRID_LICENSE_KEY=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true
FRED_API_KEY=
NEWSAPI_KEY=
